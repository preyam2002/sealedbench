SUI_NETWORK=testnet
# Optional RPC override. Leave unset to use the built-in defaults: the web app
# tries the archival official fullnode first (needed for historical queryEvents)
# then publicnode; scripts default to publicnode for object reads. Set this only
# to force a specific node.
# SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443
SUI_PRIVATE_KEY=
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=53
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SEALEDBENCH_PACKAGE_ID=0x9f6c9b056485a707d6bb8f6b5d810104cf1c44752899eef5378b5e12167bae4f
NEXT_PUBLIC_SEALEDBENCH_ACTIVE_EVAL_IDS=0xc03afb12f03da17ce90ef334b740e3bde5e80995606f7558da2c629fb97d6474
NEXT_PUBLIC_ENCLAVE_PK=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_COMPAT_BASE_URL=
SEALEDBENCH_LOCAL_MODEL_PATH=enclave/models/smollm2-135m-instruct-q2_k.gguf
# Model target baked into the enclave EIF (measured in the PCRs). Set to the same
# values passed as --build-arg to `make build-enclave` and to
# tools/gen-enclave-proxy-manifest.ts --model-endpoint. The api key above is a
# per-request input and is NEVER baked into the image.
SEALEDBENCH_MODEL_ENDPOINT=http://127.0.0.1:8081
SEALEDBENCH_MODEL_ID=smollm2-135m-instruct-q2_k
SEALEDBENCH_MODEL_PROVIDER=openai
# Set to 1 to skip tests that need live testnet RPC/Walrus/Seal (offline/CI mode).
SEALEDBENCH_SKIP_NETWORK=
SEALEDBENCH_ENCLAVE_CAP_ID=0x147c132bad4b40574e6717126309bd6e32d8f42b780c1dc925948876648a6017
SEALEDBENCH_ENCLAVE_CONFIG_ID=
SEALEDBENCH_ENCLAVE_TYPE=0x9f6c9b056485a707d6bb8f6b5d810104cf1c44752899eef5378b5e12167bae4f::attestation::SEALEDBENCH
SEALEDBENCH_PCRS_JSON=enclave/out/pcr-values.json
SEALEDBENCH_PCR0=
SEALEDBENCH_PCR1=
SEALEDBENCH_PCR2=
SEALEDBENCH_ATTESTATION_PATH=
SEALEDBENCH_ATTESTATION_BASE64=
SEALEDBENCH_ENABLE_RUNS=false
SEALEDBENCH_ENCLAVE_URL=http://127.0.0.1:3321
SEALEDBENCH_ENCLAVE_OBJECT_ID=
SEALEDBENCH_REPO_ROOT=
