#[test_only]
#[allow(implicit_const_copy)]
module sealedbench::attested_score_tests;

use enclave::enclave;
use sealedbench::attested_score;
use std::string;
use sui::{object, test_scenario as ts};

// Test vectors generated by tools/gen-attestation-vectors.ts (fixed seed).
public struct TESTW has drop {}

const PK: vector<u8> = x"79b5562e8fe654f94078b112e8a98ba7901f853ae695bed7e0e3910bad049664";
const SCORE_SIG: vector<u8> =
    x"3db884b66788ac14e6fbb56401d7a4ddd14f3ab7796d2fc1c68a4c2bce46b9e96d6aca516c615da53200f3760170d7cb70c7f9dd883b0b9125671c800384c705";
const TS: u64 = 1744038900000;
const SEAL_ID: address = @0xabababababababababababababababababababababababababababababababab;
const ITEMS_HASH: vector<u8> =
    x"0707070707070707070707070707070707070707070707070707070707070707";

#[test]
fun score_signature_verifies() {
    let mut scenario = ts::begin(@0xA11CE);
    let e = enclave::new_enclave_for_testing<TESTW>(PK, ts::ctx(&mut scenario));

    let ok = attested_score::verify_score_signature(
        &e,
        object::id_from_address(SEAL_ID),
        string::utf8(b"demo/clean-open-model-2024-10"),
        37,
        50,
        ITEMS_HASH,
        string::utf8(b"trace-blob-xyz"),
        TS,
        &SCORE_SIG,
    );
    assert!(ok, 0);

    enclave::destroy(e);
    ts::end(scenario);
}

#[test]
fun score_signature_rejects_tampered_score() {
    let mut scenario = ts::begin(@0xA11CE);
    let e = enclave::new_enclave_for_testing<TESTW>(PK, ts::ctx(&mut scenario));

    // score_num 38 != signed 37 -> signature must not verify.
    let ok = attested_score::verify_score_signature(
        &e,
        object::id_from_address(SEAL_ID),
        string::utf8(b"demo/clean-open-model-2024-10"),
        38,
        50,
        ITEMS_HASH,
        string::utf8(b"trace-blob-xyz"),
        TS,
        &SCORE_SIG,
    );
    assert!(!ok, 0);

    enclave::destroy(e);
    ts::end(scenario);
}

#[test]
fun score_signature_rejects_tampered_model() {
    let mut scenario = ts::begin(@0xA11CE);
    let e = enclave::new_enclave_for_testing<TESTW>(PK, ts::ctx(&mut scenario));

    let ok = attested_score::verify_score_signature(
        &e,
        object::id_from_address(SEAL_ID),
        string::utf8(b"demo/contaminated-model"),
        37,
        50,
        ITEMS_HASH,
        string::utf8(b"trace-blob-xyz"),
        TS,
        &SCORE_SIG,
    );
    assert!(!ok, 0);

    enclave::destroy(e);
    ts::end(scenario);
}
